# === LLM (DeepSeek by default; switch to Claude by changing 3 lines below) ===
# IMPORTANT: ANTHROPIC_API_KEY must match the provider set by ANTHROPIC_BASE_URL below.
#   - If ANTHROPIC_BASE_URL points to DeepSeek (default), put your DeepSeek key here
#   - If ANTHROPIC_BASE_URL is commented out, put your Anthropic Claude key here
# Putting the wrong provider's key here is harmless (it will 401) but wastes time.
ANTHROPIC_API_KEY=sk-...
# DeepSeek's Anthropic-compatible endpoint (default). To use real Claude, comment this line out.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# Model: deepseek-v4-flash (default), deepseek-v4-pro, or any Claude model like claude-opus-4-7
LLM_MODEL=deepseek-v4-flash

# === MiniMax TTS ===
MINIMAX_API_KEY=...
MINIMAX_GROUP_ID=...
MINIMAX_VOICE_ID=male-qn-qingse

# === Misc ===
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai

# Optional: overrides project root (tests use this; leave blank in real .env)
PROJECT_ROOT=
