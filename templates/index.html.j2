<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <title>{{ date }} · AI 投资晨读</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
{% if mode == "intro" %}
  <div class="frame-intro">
    <div style="text-align:center">
      <h1>AI 投资晨读</h1>
      <div class="sub">{{ date }} · 第 {{ episode }} 期</div>
    </div>
  </div>
{% elif mode == "outro" %}
  <div class="frame-outro">
    <div style="text-align:center">
      <h1>明天见</h1>
      <div class="sub">点赞 · 关注 · 转发</div>
    </div>
  </div>
{% elif mode == "toc" %}
  <div class="frame-toc">
    <div class="toc-inner">
      <h2>今日 {{ items|length }} 条 · AI 投资晨读</h2>
      <ol class="toc-list">
        {% for item in items %}
          <li><span class="toc-rank">{{ "%02d"|format(item.rank) }}</span><span class="toc-title">{{ item.title }}</span></li>
        {% endfor %}
      </ol>
    </div>
  </div>
{% elif mode == "card" %}
  {% set item = items[card_index] %}
  <div class="frame-card">
    {% include "_card.html.j2" %}
    <div class="progress">
      <div class="progress-bar"><div class="progress-fill" style="width: {{ (item.rank / items|length * 100)|round(0, 'floor') }}%"></div></div>
      <div class="progress-text">{{ item.rank }} / {{ items|length }}</div>
    </div>
  </div>
{% else %}
  <div class="page-list">
    <header>
      <h1>AI 投资晨读</h1>
      <div class="meta">{{ date }} · 第 {{ episode }} 期 · 共 {{ items|length }} 条</div>
    </header>
    {% for item in items %}
      {% include "_card.html.j2" %}
    {% endfor %}
  </div>
{% endif %}
</body>
</html>
